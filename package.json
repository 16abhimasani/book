    "stats": "bun src/trading/stats.ts",
    "backfill": "bun src/trading/backfill.ts",
    "backtest": "bun src/trading/backtest.ts",
    "book": "bun src/trading/book.ts",
    "shadow": "bun src/trading/shadow.ts",
    "verify": "bun src/trading/verify.ts",
    "grok": "bun src/trading/grok.ts",
    "snapshot": "bun src/trading/snapshot.ts",
    "watch": "bun src/trading/watcher.ts",
    "trail": "bun src/trading/trail.ts",
    "scaleout": "bun src/trading/scaleout.ts",
    "reentry": "bun src/trading/reentry.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.16.0"
